{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transcript",
  "type": "object",
  "required": ["title", "lines"],
  "properties": {
    "title": { "type": "string" },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line_id", "panel_ids", "speaker", "line_type", "text", "uncertainty_notes"],
        "properties": {
          "line_id": { "type": "string" },
          "beat_id": { "type": ["string", "null"] },
          "panel_ids": { "type": "array", "items": { "type": "string" } },
          "speaker": { "type": "string" },
          "line_type": {
            "type": "string",
            "enum": ["recap", "dialogue_quote", "sfx", "transition", "pause"]
          },
          "text": { "type": "string" },
          "visual_anchor": { "type": ["string", "null"] },
          "beat_function": { "type": ["string", "null"] },
          "pacing": { "type": ["string", "null"] },
          "uncertainty_notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "unresolved_or_uncertain": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

