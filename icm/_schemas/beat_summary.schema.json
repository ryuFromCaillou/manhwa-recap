{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BeatSummary",
  "type": "object",
  "required": ["beats", "leftover_panels"],
  "properties": {
    "beats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat_id", "panel_ids", "state_before", "trigger", "state_after", "story_function", "recap_sentence", "uncertainty_notes"],
        "properties": {
          "beat_id": { "type": "string" },
          "panel_ids": { "type": "array", "items": { "type": "string" } },
          "state_before": { "type": "string" },
          "trigger": { "type": "string" },
          "state_after": { "type": "string" },
          "emotional_shift": { "type": ["string", "null"] },
          "story_function": { "type": "string" },
          "recap_sentence": { "type": "string" },
          "uncertainty_notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "leftover_panels": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
